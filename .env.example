# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_SOCKET_TIMEOUT=5

# PostgreSQL configuration
DB_HOST=db
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres

# Required: set a local password after copying this file to .env
DB_PASSWORD=

# Voting options
OPTION_A=Cats
OPTION_B=Dogs
