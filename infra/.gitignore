# Terraform working directories
**/.terraform/*

# Terraform state
*.tfstate
*.tfstate.*

# Terraform plan files
*.tfplan
tfplan

# Crash logs
crash.log
crash.*.log

# Variable files can contain secrets
*.tfvars
*.tfvars.json

# Allow sanitized examples
!*.tfvars.example

# Local backend configuration
backend.hcl

# Allow backend example
!backend.hcl.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration
.terraformrc
terraform.rc
